# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub – it is already in .gitignore.

# Azure AD App Registration – Client ID (from portal.azure.com)
VITE_AZURE_CLIENT_ID=1ba9e7bd-5556-4f0e-903c-33753e2a6a45

# Azure AD Tenant ID
VITE_AZURE_TENANT_ID=3abf2937-e518-43e5-b2a4-456eecfa8b00

# SharePoint hostname (no trailing slash)
VITE_SHAREPOINT_HOST=mphunited.sharepoint.com

# SharePoint site path (the part after the host)
VITE_SHAREPOINT_SITE_PATH=/sites/MPHOrders

# SharePoint Freight Quotes list name (exact display name)
VITE_FREIGHT_LIST_NAME=Freight Quotes
